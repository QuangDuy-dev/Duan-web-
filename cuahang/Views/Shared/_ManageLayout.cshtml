@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Admin Panel</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="~/css/manage.css" />
</head>
<body class="manage-body">
    <div class="admin-shell">
        <div class="topbar shadow-sm">
            <div class="topbar-leading">
                <button type="button" class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Mở menu quản trị" aria-expanded="false">
                    <i class="bi bi-list"></i>
                </button>

                <div class="topbar-brand">
                    <div class="topbar-brand-icon">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <div>
                        <div class="topbar-title">Manage Shop</div>
                        <div class="topbar-subtitle">Bảng điều khiển cửa hàng</div>
                    </div>
                </div>
            </div>

            <div class="topbar-greeting d-none d-md-flex">
                <span>Xin chào, @HttpContextAccessor.HttpContext?.Session.GetString("UserName")</span>
            </div>

            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark btn-home" aria-label="Trang chủ">
                <i class="bi bi-house-door"></i> Trang chủ
            </a>
        </div>

        <div class="admin-body">
            <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

            <aside class="sidebar">
                <div class="sidebar-header">
                    <div class="sidebar-avatar">
                        <i class="bi bi-person-circle"></i>
                    </div>
                    <div>
                        <p class="sidebar-role mb-1">Quản trị viên</p>
                        <h6 class="sidebar-title mb-0">Hệ thống cửa hàng</h6>
                    </div>
                </div>

                <nav class="sidebar-nav">
                    <a asp-controller="Manage" asp-action="Manage" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Manage" ? "active" : "")">
                        <i class="bi bi-box-seam"></i>
                        <span>Sản phẩm</span>
                    </a>
                    <a asp-controller="Manage" asp-action="News" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "News" ? "active" : "")">
                        <i class="bi bi-newspaper"></i>
                        <span>Bài báo</span>
                    </a>
                    <a asp-controller="Manage" asp-action="ManageKhuyenMai" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "ManageKhuyenMai" ? "active" : "")">
                        <i class="bi bi-ticket-perforated"></i>
                        <span>Khuyến mãi</span>
                    </a>
                    <a asp-controller="Manage" asp-action="LichSuDonHangAdmin" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "LichSuDonHangAdmin" ? "active" : "")">
                        <i class="bi bi-cart-check"></i>
                        <span>Đơn hàng</span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <a asp-controller="Home" asp-action="Index" class="sidebar-exit">
                        <i class="bi bi-box-arrow-left"></i>
                        <span>Thoát về trang chủ</span>
                    </a>
                </div>
            </aside>

            <main class="content">
                @RenderBody()
            </main>
        </div>

        <footer class="footer">
            <div class="container-fluid text-muted small">
                &copy; 2026 - Hệ thống quản lý <strong>Cửa hàng trực tuyến</strong>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/manage.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
