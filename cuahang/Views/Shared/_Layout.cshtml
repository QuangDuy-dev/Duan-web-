@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - cuahang</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* Thêm link Icons để hiện icon giỏ hàng đẹp hơn *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cuahang.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">cuahang</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        @*Nút News giới thiệu thông tin sản phẩm*@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="News" asp-action="Index">News</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="LichSuDonHangUser">Lịch sử mua hàng</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        <form class="d-flex me-3" asp-controller="Home" asp-action="Index" method="get">
                        <input class="form-control me-2" type="search" name="keyword" placeholder="Tìm kiếm sản phẩm" />
                            <button class="btn btn-outline-success" type="submit">
                         <i class="bi bi-search"></i>
                          </button>
                        </form>
                        @if (HttpContextAccessor.HttpContext?.Session?.GetString("UserName") != null)
                        {
                            <span class="me-2">
                                Chào, <strong>@(HttpContextAccessor.HttpContext?.Session?.GetString("UserName") ?? "Khách")</strong>!
                            </span>
                            <a class="btn btn-logout btn-sm btn-outline-danger me-2" asp-controller="Account" asp-action="Logout">Thoát</a>
                        }
                        else
                        {
                            <a class="nav-link text-dark me-2 login-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                        }

                        
                        @{
                            
                            var userid = Context.Session.GetString("UserId");
                        }
                        @* Nút Giỏ hàng với Badge *@
                        @if (userid!=null)
                        {
                        <a class="btn btn-primary position-relative" asp-controller="Cart" asp-action="Index"> 
                            <i class="bi bi-cart3"></i> Giỏ hàng
                            <span id="cart-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                0
                            </span>
                            </a>
                        }
                        else
                        {
                            @* Khi chưa đăng nhập: Gọi hàm Javascript thông báo *@
              <button class="btn btn-secondary position-relative" onclick="requireLogin()">
                   <i class="bi bi-cart3"></i> Giỏ hàng
                   <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary">
                          0
                   </span>
             </button>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <div class="menu">
        <div class="toggle">
            <ion-icon name="share-social"></ion-icon>
        </div>
        <li style="--i: 0; --clr: #1877f2">
            <a href="https://facebook.com"><i class="fab fa-facebook-f"></i></a>
        </li>
        <li style="--i: 1; --clr: #1877f2">
            <a href="https://zalo.me/0123456789" target="_blank">
                <svg class="zalo-icon" viewBox="0 0 48 48">
                    <path fill="#0068FF" d="M24 4C13 4 4 11.5 4 20.5c0 5.3 3.3 10 8.5 13.1L10 44l10.4-5.5c1.2.2 2.4.3 3.6.3 11 0 20-7.5 20-16.5S35 4 24 4z" />
                    <text x="24" y="28" font-size="14" text-anchor="middle" fill="white">Zalo</text>
                </svg>
            </a>
        </li>
        <li style="--i: 2; --clr: #25d366">
            <a href="#" onclick="openCallModal('+84123456789')">
                <i class="fa-solid fa-phone"></i>
            </a>
        </li>
        <li style="--i: 3; --clr: #1b1e21">
            <a href="https://github.com/QuangDuy-dev/Duan-web-"><i class="fab fa-github"></i></a>
        </li>
        <li style="--i: 4; --clr: #ff5733">
            <a href="#"><i class="fab fa-reddit-alien"></i></a>
        </li>
        <li style="--i: 5; --clr: #0a66c2">
            <a href="#"><i class="fab fa-linkedin-in"></i></a>
        </li>
        <li style="--i: 6; --clr: #c32aa3">
            <a href="#"><i class="fab fa-instagram"></i></a>
        </li>
        <li style="--i: 7; --clr: #ff0000">
            <a href="#"><i class="fab fa-youtube"></i></a>
        </li>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - cuahang - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <div class="call-modal" id="callModal">
        <div class="modal-box">
            <p>Gọi <span id="phoneNumber"></span> ?</p>
            <div class="actions">
                <button class="ok">Gọi</button>
                <button class="cancel">Huỷ</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src='https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js'></script>

    @* SCRIPT TỰ ĐỘNG CẬP NHẬT GIỎ HÀNG *@
    <script>
        function loadCartCount() {
            $.ajax({
                url: '/Cart/GetCartCount',
                type: 'GET',
                success: function (response) {
                    $('#cart-count').text(response.count);
                },
                error: function () {
                    console.log("Không thể tải số lượng giỏ hàng.");
                }
            });
        }

        $(document).ready(function () {
            // Gọi hàm ngay khi trang web vừa tải xong
            loadCartCount();
        });
    </script>

    <script>
    function requireLogin() {
        Swal.fire({
            title: 'Bạn chưa đăng nhập!',
            text: "Vui lòng đăng nhập để xem giỏ hàng và mua sắm.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#aaa',
            confirmButtonText: 'Đăng nhập ngay',
            cancelButtonText: 'Để sau'
        }).then((result) => {
            if (result.isConfirmed) {
                // Chuyển hướng sang trang đăng nhập của bạn
                window.location.href = '/Account/Login'; 
            }
        })
    }
</script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>