@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var currentType = Context.Request.Query["type"].ToString();
    var currentKeyword = Context.Request.Query["keyword"].ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - cuahang</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* Thêm link Icons để hiện icon giỏ hàng đẹp hơn *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cuahang.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark border-bottom box-shadow mb-3 d-lg-none">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">cuahang</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContentMobile">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContentMobile">
                    <hr class="d-sm-none my-2"> 
                    <div class="d-flex align-items-center gap-2 mb-3 mb-sm-0 me-sm-3">
                        <form class="d-flex flex-grow-1 flex-sm-grow-0" asp-controller="Home" asp-action="Index" method="get">
                            <input class="form-control form-control-sm me-1" type="search" name="keyword" placeholder="Tìm..." style="max-width: 120px;" />
                            <button class="btn btn-sm btn-outline-success" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </form>

                        @{
                            var userLevel = Context.Session.GetString("UserLevel");
                        }
                        @if (userLevel == "2")
                        {
                            <a href="/Manage/Manage" class="btn btn-warning shadow-sm me-2">
                                <i class="bi bi-gear"></i>
                            </a>
                        }

                        @if (HttpContextAccessor.HttpContext?.Session?.GetString("UserName") != null)
                        {
                            <a class="btn btn-sm btn-outline-danger" asp-controller="Account" asp-action="Logout" title="Thoát @(HttpContextAccessor.HttpContext?.Session?.GetString("UserName"))">
                                <i class="bi bi-box-arrow-right"></i>
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-primary btn-mobile-login" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-person-circle text-white"></i>
                            </a>
                        }

                        @{
                            
                            var userid = Context.Session.GetString("UserId");
                        }

                        @* Nút Giỏ hàng với Badge *@
                        @if (userid != null)
                        {
                            <a class="btn btn-sm btn-primary position-relative" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3"></i>
                                <span class="cart-count-badge position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem;">0</span>
                            </a>
                        }
                        else
                        {
                            @* Khi chưa đăng nhập: Gọi hàm Javascript thông báo *@
                            <button class="btn btn-sm btn-secondary" onclick="requireLogin()">
                                <i class="bi bi-cart3"></i>
                            </button>
                        }
                    </div>

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="News" asp-action="Index">News</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Account" asp-action="LichSuDonHangUser">Lịch sử</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <nav class="navbar navbar-expand-lg navbar-light border-bottom box-shadow mb-3 d-none d-lg-block">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">cuahang</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse-pc">
                    <span class="navbar-toggler-icon border-white"></span>
                </button>
                <div class="navbar-collapse collapse navbar-collapse-pc d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        @*Nút News giới thiệu thông tin sản phẩm*@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="News" asp-action="Index">News</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="LichSuDonHangUser">Lịch sử mua hàng</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        <form class="d-flex me-3" asp-controller="Home" asp-action="Index" method="get">
                            <div class="input-group">
                                <input class="form-control" type="search" name="keyword" placeholder="Tìm kiếm..." aria-label="Search">
                                <button class="btn btn-outline-secondary bg-white border-start-0" type="submit" style="color: gray; border-color: #ced4da;">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </form>

                        @if (userLevel == "2")
                        {
                            <a href="/Manage/Manage" class="btn btn-warning shadow-sm me-2">
                                <i class="bi bi-gear text-dark"></i>
                            </a>
                        }

                        @if (HttpContextAccessor.HttpContext?.Session?.GetString("UserName") != null)
                        {
                            <span class="me-2">
                                Chào, <strong>@(HttpContextAccessor.HttpContext?.Session?.GetString("UserName") ?? "Khách")</strong>!
                            </span>
                            <a class="btn btn-sm btn-outline-danger me-2" asp-controller="Account" asp-action="Logout">Thoát</a>
                        }
                        else
                        {
                            <a class="nav-link text-dark me-2" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                        }

                        @* Nút Giỏ hàng với Badge *@
                        @if (userid != null)
                        {
                            <a class="btn btn-primary position-relative" asp-controller="Cart" asp-action="Index"> 
                                <i class="bi bi-cart3"></i> Giỏ hàng
                                <span id="cart-count" class="cart-count-badge position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    0
                                </span>
                            </a>
                        }
                        else
                        {
                            @* Khi chưa đăng nhập: Gọi hàm Javascript thông báo *@
                            <button class="btn btn-secondary position-relative" onclick="requireLogin()">
                                <i class="bi bi-cart3"></i> Giỏ hàng
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary">
                                    0
                                </span>
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div class="category-bar">
    <div class="container">
        <div class="category-scroll-wrapper text-white">
            @* 1. All Products *@
            <a href="@Url.Action("Index", "Home", new { keyword = currentKeyword })" 
               class="cat-pill @(string.IsNullOrEmpty(currentType) ? "active" : "")">
                <i class="bi bi-house-door"></i> Tất cả
            </a>

            @* 2. Category 1 *@
            <a href="@Url.Action("Index", "Home", new { type = "1", keyword = currentKeyword })" 
               class="cat-pill @(currentType == "1" ? "active" : "")">
                <i class="bi bi-phone"></i> Điện thoại
            </a>

            @* 3. Category 2 *@
            <a href="@Url.Action("Index", "Home", new { type = "2", keyword = currentKeyword })" 
               class="cat-pill @(currentType == "2" ? "active" : "")">
                <i class="bi bi-headset"></i> Phụ kiện ĐT
            </a>

            @* 4. Category 4 *@
            <a href="@Url.Action("Index", "Home", new { type = "4", keyword = currentKeyword })" 
               class="cat-pill @(currentType == "4" ? "active" : "")">
                <i class="bi bi-laptop"></i> Máy tính
            </a>

            @* 5. Category 3 *@
            <a href="@Url.Action("Index", "Home", new { type = "3", keyword = currentKeyword })" 
                class="cat-pill @(currentType == "3" ? "active" : "")">
                <i class="bi bi-mouse3"></i> Phụ kiện MT
            </a>
            </div>
        </div>
    </div>
    </nav>

    </div>

    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <div class="menu">
