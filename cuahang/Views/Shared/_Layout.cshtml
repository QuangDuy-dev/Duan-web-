    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src='https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js'></script>

    @* SCRIPT TỰ ĐỘNG CẬP NHẬT GIỎ HÀNG *@
    <script>
        function loadCartCount() {
            $.ajax({
                url: '/Cart/GetCartCount',
                type: 'GET',
                success: function (response) {
                    $('#cart-count').text(response.count);
                },
                error: function () {
                    console.log("Không thể tải số lượng giỏ hàng.");
                }
            });
        }

        $(document).ready(function () {
            // Gọi hàm ngay khi trang web vừa tải xong
            loadCartCount();
        });
    </script>

    <script>
    function requireLogin() {
        Swal.fire({
            title: 'Bạn chưa đăng nhập!',
            text: "Vui lòng đăng nhập để xem giỏ hàng và mua sắm.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#aaa',
            confirmButtonText: 'Đăng nhập ngay',
            cancelButtonText: 'Để sau'
        }).then((result) => {
            if (result.isConfirmed) {
                // Chuyển hướng sang trang đăng nhập của bạn
                window.location.href = '/Account/Login'; 
            }
        })
    }
</script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>