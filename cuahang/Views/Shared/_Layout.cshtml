<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - cuahang</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cuahang.styles.css" asp-append-version="true" />
     @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
    <div class="container-fluid d-flex justify-content-between">

        <!-- LEFT SIDE-->
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Trang chủ</a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Đăng ký</a>
            </li>

            <li class="nav-item">
                <a class="nav-link btn btn-outline-primary" asp-controller="Account" asp-action="Login">Đăng nhập</a>
            </li>
        </ul>

        <!-- RIGHT SIDE-->
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="btn btn-success"asp-controller="HoaDon"asp-action="Cart">🛒 Giỏ hàng </a>
            </li>
        </ul>

    </div>
</nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - cuahang - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
