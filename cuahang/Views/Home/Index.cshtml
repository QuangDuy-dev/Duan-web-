@model IEnumerable<cuahang.Models.SanPham>

@{
    var keyword = Context.Request.Query["keyword"];
    var userLevel = Context.Session.GetString("UserLevel");
}

@if (userLevel == "2")
{
    <div class="text-end mb-3">
        <a href="/Manage/Manage" class="btn btn-warning shadow-sm">
            <i class="bi bi-gear"></i> Manage
        </a>
    </div>
}

@if (Model == null || !Model.Any())
{
    if (!string.IsNullOrEmpty(keyword))
    {
        <div class="alert alert-warning text-center">
            Không tìm thấy sản phẩm phù hợp!
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            Hiện chưa có sản phẩm nào trong cửa hàng!
        </div>
    }
}

<div class="container mt-5">
    <h2 class="text-center mb-4 text-uppercase fw-bold text-primary">Cửa Hàng Trực Tuyến</h2>

    @if (!string.IsNullOrEmpty(keyword))
    {
        <p class="text-center">
            Kết quả tìm kiếm cho:
            <strong class="text-danger">@keyword</strong>
        </p>
    }
    
    <div class="row">
        @foreach (var item in Model ?? Enumerable.Empty<cuahang.Models.SanPham>())
        {
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="text-center p-3">
                        <img src="~/image/@(item?.ImageUrl ?? "default.jpg")"
                             class="card-img-top img-fluid"
                             style="max-height: 200px; object-fit: contain;"
                             alt="@(item?.TenSP ?? "Sản phẩm")"
                             onerror="this.src='https://via.placeholder.com/200?text=No+Image'">
                    </div>

                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title fw-bold">@(item?.TenSP ?? "Sản phẩm chưa có tên")</h5>
                        <p class="card-text text-muted small">@(item?.MoTa ?? "Không có mô tả")</p>

                        <div class="mt-auto">
                            <h5 class="text-danger">
                                @((item?.Gia ?? 0).ToString("N0")) <span class="small">VNĐ</span>
                            </h5>
                            @* data-id dùng để gửi ID lên Server *@
                            @{ var userid = Context.Session.GetString("UserId");
                            }
                            @if (userid != null)
                            {
            <button class="btn btn-primary w-100">Thêm vào giỏ</button>
                            }
                            else
                            {
            <button class="btn btn-outline-secondary w-100" onclick="requireLogin()">Thêm vào giỏ</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;
    }
</style>

@section Scripts {
    @* Đảm bảo chỉ gọi jQuery một lần và đúng đường dẫn *@
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.btn-add-to-cart').off('click').on('click', function() {
                var productId = $(this).data('id');

                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: { id: productId },
                    success: function(response) {
                        if(response.success) {
                            // HIỆN THÔNG BÁO: Sử dụng response.productName từ Controller gửi về
                            alert("Đã thêm \"" + response.productName + "\" vào giỏ hàng thành công!");

                            // CẬP NHẬT GIAO DIỆN: Làm mới để thấy số lượng giỏ hàng thay đổi trên header
                            location.reload();
                        } else {
                            alert("Lỗi: " + response.message);
                        }
                    },
                    error: function() {
                        alert("Không thể kết nối với máy chủ. Vui lòng kiểm tra lại SQL Server!");
                    }
                });
            });
        });
    </script>
}