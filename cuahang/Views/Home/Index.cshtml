@model IEnumerable<cuahang.Models.SanPham>

@{
    var keyword = Context.Request.Query["keyword"];
    var currentType = ViewBag.CurrentType as string;
}

@if (Model == null || !Model.Any())
{
    if (!string.IsNullOrEmpty(keyword))
    {
        <div class="alert alert-warning text-center">
            Không tìm thấy sản phẩm phù hợp!
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            Hiện chưa có sản phẩm nào trong cửa hàng!
        </div>
    }
}

<div class="container mt-5">
    <h2 class="text-center mb-4 text-uppercase fw-bold text-primary">Cửa Hàng Trực Tuyến</h2>
    <div class="row mb-4">
        <div class="col-12 text-center">
            <div class="btn-group shadow-sm" role="group" aria-label="Product Categories">
                @* Nút Tất cả *@
                <a href="@Url.Action("Index", "Home", new { keyword = keyword })" 
                   class="btn @(string.IsNullOrEmpty(currentType) ? "btn-primary" : "btn-outline-primary")">
                    Tất cả
                </a>

                @* Nút Điện thoại *@
                <a href="@(currentType == "1" ? Url.Action("Index", "Home", new { keyword = keyword }) : Url.Action("Index", "Home", new { type = "1", keyword = keyword }))" 
                   class="btn @(currentType == "1" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-phone"></i> Điện thoại
                </a>

                @* Nút Phụ kiện *@
                <a href="@(currentType == "2" ? Url.Action("Index", "Home", new { keyword = keyword }) : Url.Action("Index", "Home", new { type = "2", keyword = keyword }))" 
                   class="btn @(currentType == "2" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-headset"> </i> Phụ kiện điện thoại
                </a>

                <a href="@(currentType == "4" ? Url.Action("Index", "Home", new { keyword = keyword }) : Url.Action("Index", "Home", new { type = "4", keyword = keyword }))" 
                   class="btn @(currentType == "4" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-laptop"> </i> Máy tính
                </a>

                <a href="@(currentType == "3" ? Url.Action("Index", "Home", new { keyword = keyword }) : Url.Action("Index", "Home", new { type = "3", keyword = keyword }))" 
                   class="btn @(currentType == "3" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-mouse3"> </i> Phụ kiện máy tính
                </a>

            </div>

            @if (ViewBag.DisplayBrands != null && ((List<dynamic>)ViewBag.DisplayBrands).Count > 0)
            {
                <div class="brand-container mt-4">
                    @foreach (var b in ViewBag.DisplayBrands)
                    {
                        bool isActive = (ViewBag.CurrentBrand == b.Code);
                        
                        <a href="@Url.Action("Index", "Home", new { 
                                keyword = keyword, 
                                type = currentType, 
                                brand = (isActive ? "" : b.Code) 
                           })" 

                           class="btn brand-card @(isActive ? "active" : "") p-0" title="@b.Code">
                            <img src="~/image/brands/@(b.Name).png" alt="@b.Name" onerror="this.src='https://via.placeholder.com/50?text=@b.Name'" />
                        </a>
                    }
                </div>
            }

        </div>
    </div>

    @if (!string.IsNullOrEmpty(keyword))
    {
        <p class="text-center">
            Kết quả tìm kiếm cho:
            <strong class="text-danger">@keyword</strong>
        </p>
    }

    <div class="row custom-mobile-row">
        @foreach (var item in Model ?? Enumerable.Empty<cuahang.Models.SanPham>())
        {
            <div class="col-6 col-md-4 col-lg-3 mb-3 mb-md-4">
                <div class="card h-100 shadow-sm border-0 product-card">
                    <div class="text-center p-2 p-sm-3">
                        <img src="~/image/@(item?.ImageUrl ?? "default.jpg")"
                            style="max-height: 200px; object-fit: contain;"
                            class="card-img-top img-fluid product-img"
                            alt="@(item?.TenSP ?? "Sản phẩm")"
                            onerror="this.src='https://via.placeholder.com/200?text=No+Image'">
                    </div>

                    <div class="card-body d-flex flex-column p-2 p-sm-3">
                        <h6 class="card-title fw-bold text-truncate mobile-title text-center">@(item?.TenSP ?? "Sản phẩm chưa có tên")</h6>
                        
                        <p class="card-text text-muted small text-truncate-2 text-center">@(item?.MoTa ?? "Không có mô tả")</p>
                        
                        @{
                            var ratings = item.ChiTietHoaDons?.Where(c => c.DiemDanhGia > 0).ToList()
                            ?? new List<cuahang.Models.ChiTietHoaDon>();

                            double avgRating = ratings.Any() ? ratings.Average(c => c.DiemDanhGia.Value) : 0;
                        }

                        <div class="mb-2 text-center d-none d-sm-block">
                            @if (ratings.Any())
                            {
                                <span class="text-warning">
                                    <i class="bi bi-star-fill"></i>
                                    <span class="fw-bold text-dark d-none d-sm-inline">@avgRating.ToString("0.0")</span>
                                </span>
                                <span class="text-muted small d-none d-sm-inline">(@ratings.Count lượt)</span>
                            }
                            else
                            {
                                <span class="text-muted small italic d-none d-sm-inline">Chưa có đánh giá</span>
                                <span class="text-muted small italic d-sm-none"><i class="bi bi-star text-secondary"></i></span>
                            }
                        </div>

                        <div class="mt-auto d-flex flex-column flex-sm-column align-items-center">
                            
                        <div class="d-flex align-items-center flex-sm-column mobile-price-rating-container">
                            <div class="d-flex align-items-center flex-sm-column gap-2 gap-sm-0">
                                <h5 class="text-danger mb-0 mb-sm-2 product-price">
                                    @((item?.Gia ?? 0).ToString("N0"))<span class="small d-none d-sm-inline"> VNĐ</span><span class="small d-sm-none">đ</span>
                                </h5>

                                <div class="d-sm-none d-flex align-items-center">
                                    @if (ratings.Any())
                                    {
                                        <span class="text-warning small me-1"><i class="bi bi-star-fill"></i></span>
                                        <span class="small fw-bold">@avgRating.ToString("0.0")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><i class="bi bi-star"></i></span>
                                    }
                                </div>
                            </div>
                            
                            @* data-id dùng để gửi ID lên Server *@
                            <button class="btn btn-primary btn-sm shadow-sm btn-add-to-cart rounded-circle d-sm-none"
                                    data-id="@item?.Id">
                                <i class="bi bi-cart-plus"></i>
                            </button>

                            <button class="btn btn-primary w-100 shadow-sm btn-add-to-cart d-none d-sm-block"
                                    data-id="@item?.Id">
                                <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.btn-add-to-cart').off('click').on('click', function() {
                // --- LOGIC KIỂM TRA ĐĂNG NHẬP ---
                var userLevel = '@Context.Session.GetString("UserLevel")';

                if (!userLevel || userLevel === "") {
                    alert("Vui lòng đăng nhập để thực hiện chức năng thêm vào giỏ hàng!");
                    // Chuyển hướng người dùng đến trang đăng nhập (kiểm tra lại đường dẫn này)
                    window.location.href = "/Account/Login";
                    return; // Ngừng thực hiện các lệnh bên dưới
                }
                // --------------------------------

                var productId = $(this).data('id');

                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: { id: productId },
                    success: function(response) {
                        if(response.success) {
                            alert("Đã thêm \"" + response.productName + "\" vào giỏ hàng thành công!");
                            location.reload();
                        } else {
                            alert("Lỗi: " + response.message);
                        }
                    },
                    error: function() {
                        alert("Không thể kết nối với máy chủ. Vui lòng kiểm tra lại SQL Server!");
                    }
                });
            });
        });
    </script>
}