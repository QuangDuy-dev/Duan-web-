@model IEnumerable<cuahang.Models.SanPham>

@{
    var keyword = Context.Request.Query["keyword"];
}

@if (Model == null || !Model.Any())
{
    if (!string.IsNullOrEmpty(keyword))
    {
        <div class="alert alert-warning text-center">
            Không tìm thấy sản phẩm phù hợp!
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            Hiện chưa có sản phẩm nào trong cửa hàng!
        </div>
    }
}

<div class="container mt-5">
    <h2 class="text-center mb-4 text-uppercase fw-bold text-primary">Cửa Hàng Trực Tuyến</h2>

    @if (!string.IsNullOrEmpty(keyword))
    {
        <p class="text-center">
            Kết quả tìm kiếm cho:
            <strong class="text-danger">@keyword</strong>
        </p>
    }

    <div class="row custom-mobile-row">
        @foreach (var item in Model ?? Enumerable.Empty<cuahang.Models.SanPham>())
        {
            <div class="col-6 col-md-4 col-lg-3 mb-3 mb-md-4">
                <div class="card h-100 shadow-sm border-0 product-card">
                    <div class="text-center p-2 p-sm-3">
                        <img src="~/image/@(item?.ImageUrl ?? "default.jpg")"
                            style="max-height: 200px; object-fit: contain;"
                            class="card-img-top img-fluid product-img"
                            alt="@(item?.TenSP ?? "Sản phẩm")"
                            onerror="this.src='https://via.placeholder.com/200?text=No+Image'">
                    </div>

                    <div class="card-body d-flex flex-column p-2 p-sm-3">
                        <h6 class="card-title fw-bold text-truncate mobile-title text-center">@(item?.TenSP ?? "Sản phẩm chưa có tên")</h6>
                        
                        <p class="card-text text-muted small text-truncate-2 d-none d-sm-block text-center">@(item?.MoTa ?? "Không có mô tả")</p>
                        
                        @{
                            var ratings = item.ChiTietHoaDons?.Where(c => c.DiemDanhGia > 0).ToList()
                            ?? new List<cuahang.Models.ChiTietHoaDon>();

                            double avgRating = ratings.Any() ? ratings.Average(c => c.DiemDanhGia.Value) : 0;
                        }

                        <div class="mb-2 text-center text-sm-center text-start">
                            @if (ratings.Any())
                            {
                                <span class="text-warning">
                                    <i class="bi bi-star-fill"></i>
                                    <span class="fw-bold text-dark d-none d-sm-inline">@avgRating.ToString("0.0")</span>
                                </span>
                                <span class="text-muted small d-none d-sm-inline">(@ratings.Count lượt)</span>
                            }
                            else
                            {
                                <span class="text-muted small italic d-none d-sm-inline">Chưa có đánh giá</span>
                                <span class="text-muted small italic d-sm-none"><i class="bi bi-star text-secondary"></i></span>
                            }
                        </div>

                        <div class="mt-auto d-flex flex-row flex-sm-column justify-content-between align-items-center">
                            <h5 class="text-danger mb-0 mb-sm-2 product-price">
                                @((item?.Gia ?? 0).ToString("N0"))<span class="small d-none d-sm-inline"> VNĐ</span><span class="small d-sm-none">đ</span>
                            </h5>
                            
                            @* data-id dùng để gửi ID lên Server *@
                            <button class="btn btn-primary btn-sm shadow-sm btn-add-to-cart rounded-circle d-sm-none"
                                    data-id="@item?.Id">
                                <i class="bi bi-cart-plus"></i>
                            </button>

                            <button class="btn btn-primary w-100 shadow-sm btn-add-to-cart d-none d-sm-block"
                                    data-id="@item?.Id">
                                <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        transition: 0.3s;
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.btn-add-to-cart').off('click').on('click', function() {
                // --- LOGIC KIỂM TRA ĐĂNG NHẬP ---
                var userLevel = '@Context.Session.GetString("UserLevel")';

                if (!userLevel || userLevel === "") {
                    alert("Vui lòng đăng nhập để thực hiện chức năng thêm vào giỏ hàng!");
                    // Chuyển hướng người dùng đến trang đăng nhập (kiểm tra lại đường dẫn này)
                    window.location.href = "/Account/Login";
                    return; // Ngừng thực hiện các lệnh bên dưới
                }
                // --------------------------------

                var productId = $(this).data('id');

                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: { id: productId },
                    success: function(response) {
                        if(response.success) {
                            alert("Đã thêm \"" + response.productName + "\" vào giỏ hàng thành công!");
                            location.reload();
                        } else {
                            alert("Lỗi: " + response.message);
                        }
                    },
                    error: function() {
                        alert("Không thể kết nối với máy chủ. Vui lòng kiểm tra lại SQL Server!");
                    }
                });
            });
        });
    </script>
}