@model cuahang.Models.SanPham

@{
    ViewData["Title"] = Model.TenSP;
    var ratings = Model.ChiTietHoaDons?.Where(c => c.DiemDanhGia > 0).ToList() 
                  ?? new List<cuahang.Models.ChiTietHoaDon>();
    double avgRating = ratings.Any() ? ratings.Average(c => c.DiemDanhGia.Value) : 0;
}

<div class="container mt-5">
    <a asp-controller="Home" asp-action="Index" class="back-home" title="Back to Home">&lt; </a>
    <div class="row bg-white p-4 shadow-sm rounded">
        <div class="col-md-5 text-center">
            <img src="~/image/@(Model.ImageUrl ?? "default.jpg")" 
                 class="img-fluid rounded product-img-detail" 
                 alt="@Model.TenSP"
                 onerror="this.src='https://via.placeholder.com/400?text=No+Image'"
                 style="max-height: 400px; object-fit: contain;">
        </div>

        <div class="col-md-7">
            @if (!string.IsNullOrEmpty(ViewBag.BrandCode))
            {
                <div class="mb-2">
                    <a href="@Url.Action("Index", "Home", new { brand = ViewBag.BrandCode })" class="text-decoration-none">
                    <img src="~/image/brands/@(ViewBag.BrandName).png" 
                         alt="@ViewBag.BrandName" 
                         style="height: 30px;" 
                         onerror="this.style.display='none'" />
                    <span class="text-muted ms-1 small">Thương hiệu: <strong>@ViewBag.BrandName</strong></span>
                    </a>
                </div>
            }

            <h2 class="fw-bold">@Model.TenSP</h2>

            <div class="mb-3">
                @if (ratings.Any())
                {
                    <span class="text-warning fs-5">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Round(avgRating))
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            else
                            {
                                <i class="bi bi-star text-secondary"></i>
                            }
                        }
                    </span>
                    <span class="ms-2 fw-bold">@avgRating.ToString("0.0")</span>
                    <span class="text-muted small">(@ratings.Count Đánh giá)</span>
                }
                else
                {
                    <span class="text-muted italic small">Chưa có đánh giá</span>
                }
            </div>
            
            <div class="d-inline-flex align-items-center justify-content-start gap-2 mb-2">
                <h3 class="text-danger fw-bold m-0 p-0">@Model.Gia.ToString("N0") đ</h3>
                <button class="btn btn-primary btn-sm shadow-sm btn-add-to-cart d-sm-none"
                        data-id="@Model.Id">
                        <i class="bi bi-cart-plus"></i>
                </button>
            </div>

            <div class="card bg-light border-0 mb-4">
                <div class="card-body">
                    <h6 class="fw-bold">Mô tả sản phẩm:</h6>
                    <p class="card-text text-muted">@Model.MoTa</p>
                </div>
            </div>

            <div class="mb-4">
                <p><strong>Trạng thái:</strong> 
                    @if (Model.SoLuongTon > 0) {
                        <span class="badge bg-success">Còn @Model.SoLuongTon sản phẩm</span>
                    } else {
                        <span class="badge bg-danger">Hết hàng</span>
                    }
                </p>
            </div>
            <div class="row g-2">
                <div class="col-6">
                        <button class="btn btn-primary w-100 shadow-sm btn-add-to-cart d-none d-sm-block"
                            data-id="@Model.Id">
                            <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                        </button>
                </div>
                <div class="col-6">
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 shadow-sm d-flex align-items-center justify-content-center d-none d-sm-block">Quay lại</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .product-img-detail {
        transition: transform .3s;
    }
    .product-img-detail:hover {
        transform: scale(1.05);
    }
@@media (max-width: 767px){
    .product-img-detail {
        max-height: 250px;
        width: auto;
        object-fit: contain;
    }
}
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.btn-add-to-cart').off('click').on('click', function() {
                // --- LOGIC KIỂM TRA ĐĂNG NHẬP ---
                var userLevel = '@Context.Session.GetString("UserLevel")';

                if (!userLevel || userLevel === "") {
                    alert("Vui lòng đăng nhập để thực hiện chức năng thêm vào giỏ hàng!");
                    // Chuyển hướng người dùng đến trang đăng nhập (kiểm tra lại đường dẫn này)
                    window.location.href = "/Account/Login";
                    return; // Ngừng thực hiện các lệnh bên dưới
                }
                // --------------------------------

                var productId = $(this).data('id');

                $.ajax({
                    url: '/Cart/AddToCart',
                    type: 'POST',
                    data: { id: productId },
                    success: function(response) {
                        if(response.success) {
                            alert("Đã thêm \"" + response.productName + "\" vào giỏ hàng thành công!");
                            location.reload();
                        } else {
                            alert("Lỗi: " + response.message);
                        }
                    },
                    error: function() {
                        alert("Không thể kết nối với máy chủ. Vui lòng kiểm tra lại SQL Server!");
                    }
                });
            });
        });
    </script>
}