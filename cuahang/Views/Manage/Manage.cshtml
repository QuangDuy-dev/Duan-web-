@model IEnumerable<cuahang.Models.SanPham>
@{
    ViewBag.Title = "Quản lý sản phẩm";
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
}

<h3 class="mb-4">
    <i class="bi bi-box-seam"></i> Quản lý sản phẩm
</h3>

<div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <span id="formTitle"><i class="bi bi-plus-circle"></i> Thêm sản phẩm</span>
        <button type="button" id="btnReset" class="btn btn-sm btn-light d-none">
            <i class="bi bi-x-lg"></i> Hủy chỉnh sửa
        </button>
    </div>
    <div class="card-body">
        <form id="productForm" method="post" class="row g-3"
              data-edit-url="@Url.Action("Edit", "Manage")"
              data-create-url="@Url.Action("Create", "Manage")">
            @Html.AntiForgeryToken()

            <input type="hidden" id="editId" name="Id" value="0" />

            <div class="col-12">
                <input id="inputTenSP" name="TenSP" class="form-control" placeholder="Tên sản phẩm" required />
            </div>

            <div class="col-12">
                <input id="inputGia" name="Gia" type="number" class="form-control" placeholder="Giá" required />
            </div>

            <div class="col-12">
                <input id="inputSoLuong" name="SoLuongTon" type="number" class="form-control" placeholder="Số lượng" required />
            </div>

            <div class="col-12">
                <input id="inputImageUrl" name="ImageUrl" class="form-control" placeholder="Tên ảnh" />
            </div>

            <div class="col-12">
                <input id="inputLoaiSp" name="LoaiSp" class="form-control" placeholder="Loại nếu là điện thoại thì là 1, còn phụ kiện thì là 2, tên hãng ghi tắc hành 2 chữ: 1 ss, 2 ip" />
            </div>

            <div class="col-12">
                <textarea id="inputMoTa" name="MoTa" class="form-control mota-textarea"
                          placeholder="Mô tả (Shift+Enter để xuống dòng)"
                          rows="1"></textarea>
            </div>

            <div class="col-12">
                <button type="button" id="btnAction" class="btn btn-success w-100">
                    <i class="bi bi-plus-lg"></i> Thêm sản phẩm
                </button>
            </div>
        </form>
    </div>
</div>

<div class="input-group mb-3">
    <span class="input-group-text">
        <i class="bi bi-search"></i>
    </span>
    <input type="text" id="searchBox" class="form-control" placeholder="Tìm sản phẩm" />
</div>

<p class="text-muted small mb-2"><i class="bi bi-info-circle"></i> Click vào hàng sản phẩm để chỉnh sửa thông tin</p>

<table class="table table-bordered table-hover shadow-sm" id="productTable">
    <thead class="table-dark text-center">
        <tr>
            <th>ID</th>
            <th>Tên</th>
            <th>Giá</th>
            <th>SL</th>
            <th>Loại</th>
            <th>Ảnh</th>
            <th>Hành động</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var sp in Model)
        {
            <tr class="text-center product-row"
                style="cursor:pointer"
                data-id="@sp.Id"
                data-ten="@sp.TenSP"
                data-gia="@sp.Gia"
                data-soluong="@sp.SoLuongTon"
                data-imageurl="@sp.ImageUrl"
                data-loai="@sp.LoaiSp"
                data-mota="@sp.MoTa">

                <td>@sp.Id</td>
                <td class="ten">@sp.TenSP</td>
                <td>@sp.Gia.ToString("N0")</td>
                <td>@sp.SoLuongTon</td>
                <td>@sp.LoaiSp</td>
                <td>
                    <img src="~/image/@sp.ImageUrl" class="product-img" />
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@sp.Id" class="btn btn-info btn-sm"
                       onclick="event.stopPropagation()">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@sp.Id" class="btn btn-danger btn-sm"
                       onclick="event.stopPropagation(); return confirm('Xóa sản phẩm này?')">
                        <i class="bi bi-trash"></i>
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
