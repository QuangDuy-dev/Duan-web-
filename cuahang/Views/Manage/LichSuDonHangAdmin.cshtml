@model IEnumerable<cuahang.Models.HoaDon>
@{
    ViewBag.Title = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
}

<h3 class="mb-4">
    <i class="bi bi-receipt"></i> Quản lý lịch sử đơn hàng
</h3>

<div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <span>Thống kê doanh thu</span>
        <div class="btn-group btn-group-sm">
            <button class="btn btn-light" onclick="updateChart('day')">Ngày</button>
            <button class="btn btn-light" onclick="updateChart('month')">Tháng</button>
            <button class="btn btn-light" onclick="updateChart('year')">Năm</button>
        </div>
    </div>
    <div class="card-body">
        <canvas id="revenueChart" style="max-height: 300px;"></canvas>
    </div>
</div>

<div class="input-group mb-3">
    <span class="input-group-text"><i class="bi bi-search"></i></span>
    <input type="text" id="searchBox" class="form-control" placeholder="Tìm theo tên khách hàng hoặc mã đơn..." />
</div>

<table class="table table-bordered table-hover shadow-sm" id="orderTable">
    <thead class="table-dark text-center">
        <tr>
            <th>Mã ĐH</th>
            <th>Ngày đặt</th>
            <th>Khách hàng</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            
        </tr>
    </thead>
    <tbody>
        @foreach (var dh in Model)
        {
                <tr class="text-center align-middle">
                    <td>#@dh.Id</td>
                    <td>@dh.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="search-name">@dh.User.Name</td>
                    <td class="fw-bold text-danger">@dh.TongTien.ToString("N0") đ</td>
                    <td>
                        <span class="badge @(dh.TrangThai == "Hoàn thành" ? "bg-success" : "bg-warning")">
                        @dh.TrangThai
                        </span>
                    </td>
                    
                </tr>
        }
    </tbody>
</table>

@section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            let myChart;

            $(document).ready(function () {
                // Khởi tạo biểu đồ trống trước
                const ctx = document.getElementById('revenueChart').getContext('2d');
                myChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: [],
                        datasets: [{
                            label: 'Doanh thu (VNĐ)',
                            data: [],
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13, 110, 253, 0.1)',
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: { 
                        responsive: true, 
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true }
                        }
                    }
                });

                // Tải dữ liệu mặc định là 'day'
                updateChart('day');

                // Xử lý tìm kiếm (giữ nguyên của bạn)
                $("#searchBox").on("keyup", function () {
                    var value = $(this).val().toLowerCase();
                    $("#orderTable tbody tr").filter(function () {
                        $(this).toggle($(this).text().toLowerCase().includes(value));
                    });
                });
            });

            function updateChart(type) {
                // Gọi Ajax lấy dữ liệu thực tế
                $.get('/Manage/GetRevenueData?type=' + type, function (data) {
                    // Cập nhật dữ liệu mới vào biểu đồ
                    myChart.data.labels = data.labels;
                    myChart.data.datasets[0].data = data.values;

                    // Vẽ lại biểu đồ
                    myChart.update();
                });
            }
        </script>
}