@model IEnumerable<cuahang.Models.BaiBao>

@{
    ViewData["Title"] = "Tin tức mới nhất";
}

<div class="container mt-4 mt-md-5">
    <h2 class="text-center mb-4 mb-md-5 fw-bold text-uppercase news-heading text-break">
        <span>Tin tức mới nhất</span>
    </h2>

    <div class="row row-cols-2 row-cols-md-2 row-cols-lg-3 g-2 g-md-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 news-card">
                    <div class="news-image-wrapper">
                        <img src="@(string.IsNullOrEmpty(item.HinhAnh) || item.HinhAnh == "0" ? "/image/default-news.webp" : item.HinhAnh)"
                             class="card-img-top" alt="@item.TieuDe"
                             style="aspect-ratio: 16/9; object-fit: cover;">
                    </div>

                    <div class="card-body d-flex flex-column text-start p-2 p-md-3">
                        <small class="text-muted mb-1 mb-md-2" style="font-size: 0.75rem;">
                            <i class="bi bi-calendar3"></i> @item.NgayDang?.ToString("dd/MM/yyyy")
                        </small>
                        
                        <h6 class="card-title fw-bold news-card-title text-break mb-1 mb-md-2" style="font-size: clamp(0.9rem, 2vw, 1.25rem);">
                            @item.TieuDe
                        </h6>

                        <p class="card-text text-secondary mb-2 mb-md-3 news-card-excerpt" style="font-size: 0.85rem;">
                            @item.NoiDung
                        </p>

                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm w-100 rounded-pill">
                                Đọc chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/css/news.css" asp-append-version="true" />
}