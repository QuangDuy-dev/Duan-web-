@model IEnumerable<cuahang.Models.CartItem>

<style>
    @@media (max-width: 767.98px) {
        .mobile-cart-item {
            display: flex;
            align-items: center;
            padding: 15px 0;
            border-bottom: 1px solid #dee2e6;
        }
        .mobile-qty-input {
            max-width: 70px;
            text-align: center;
        }
    }
</style>

<div class="container mt-5">
    <h2 class="mb-4">Giỏ hàng của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">Giỏ hàng trống! <a href="/">Tiếp tục mua sắm</a></div>
    }
    else
    {
        <div class="d-none d-md-block">
            <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Sản phẩm</th>
                    <th>Ảnh</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Tổng</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr id="row-@item?.SanPhamId">
                        <td><strong>@(item?.TenSP ?? "N/A")</strong></td>
                        <td>
                            <img src="~/image/@(item?.ImageUrl ?? "default.jpg")"
                                 width="50" class="img-thumbnail"
                                 onerror="this.src='/image/default.jpg'" />
                        </td>
                        <td>@((item?.Gia ?? 0).ToString("N0")) VNĐ</td>
                        <td>
                            <div class="d-flex" style="max-width: 120px;">
                                <input type="number" class="form-control text-center quantity-input"
                                       value="@(item?.SoLuong ?? 1)" min="1" data-id="@item?.SanPhamId"
                                       oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                            </div>
                        </td>
                        <td class="fw-bold item-total">@((item?.ThanhTien ?? 0).ToString("N0")) VNĐ</td>
                        <td>
                            <button class="btn btn-sm btn-danger btn-remove" data-id="@item?.SanPhamId">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        <div class="d-md-none">
            @foreach (var item in Model)
            {
                <div class="mobile-cart-item" id="mobile-row-@item?.SanPhamId">
                    <img src="~/image/@(item?.ImageUrl ?? "default.jpg")"
                         width="70" class="img-thumbnail me-3"
                         onerror="this.src='/image/default.jpg'" />

                    <div class="flex-grow-1">
                        <div class="fw-bold mb-1">@(item?.TenSP ?? "N/A")</div>
                        <div class="d-flex align-items-center">
                            <input type="number" class="form-control form-control-sm mobile-qty-input quantity-input"
                                   value="@(item?.SoLuong ?? 1)" min="1" data-id="@item?.SanPhamId"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                            <span class="ms-2 text-muted" style="font-size: 0.85rem;">x @((item?.Gia ?? 0).ToString("N0"))</span>
                        </div>
                    </div>

                    <div class="ms-2">
                        <button class="btn text-danger btn-remove" data-id="@item?.SanPhamId">
                            <i class="bi bi-trash fs-4"></i>
                        </button>
                    </div>
                </div>
            }
        </div>

        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Tổng cộng:</h4>
                <h4 class="text-danger fw-bold mb-0" id="cart-grand-total">
                    @((ViewBag.TongTien as decimal? ?? 0).ToString("N0")) VNĐ
                </h4>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <a href="/" class="btn btn-secondary py-2 px-4">Tiếp tục mua hàng</a>
                <a asp-controller="Cart" asp-action="Checkout" class="btn btn-success py-2 px-4">
                    Thanh toán ngay
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // 1. Xử lý cập nhật số lượng khi thay đổi ô input
            $('.quantity-input').on('change keyup', function () {
                var id = $(this).data('id');
                var qty = $(this).val();
                var row = $(this).closest('tr');
                // Chặn trường hợp xóa hết số hoặc nhập số âm
                if (qty === "" || qty < 1) {
                    return;
                }
                var dRow = $('#row-' + id);
                var mRow = $('#mobile-row-' + id);

                $.ajax({
                    url: '/Cart/UpdateQuantity',
                    type: 'POST',
                    data: { id: id, quantity: qty },
                    success: function (response) {
                        if (response.success) {
                            // Cập nhật giá trị tổng của từng dòng
                            // Lưu ý: Đảm bảo Controller trả về đúng tên thuộc tính totalItemPrice
                            dRow.find('.item-total').text(response.totalItemPrice + "đ");
                            // Cập nhật tổng cộng cuối trang
                            $('#cart-grand-total').text(response.grandTotal + "đ");
                            
                            // Sync
                            $('.quantity-input[data-id="'+id+'"]').val(qty);
                        if (typeof loadCartCount === "function") {
                            loadCartCount();
                        } 
                        else {
                            $('#cart-count').text(response.cartCount);
                        }
                        }
                    }
                });
            });

            $('.btn-remove').click(function () {
                var id = $(this).data('id');
                var row = $(this).closest('tr');

                if (confirm("Bạn có chắc muốn xóa sản phẩm này khỏi giỏ hàng?")) {
                    $.ajax({
                        url: '/Cart/RemoveFromCart',
                        type: 'POST',
                        data: { id: id },
                        success: function (response) {
                            if (response.success) {
                                // Fade out
                                $('#row-' + id + ', #mobile-row-' + id).fadeOut(400, function() {
                                    location.reload();
                                });
                            }
                        }
                    });
                }
            });
        });
    </script>
}