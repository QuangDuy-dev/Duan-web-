@model IEnumerable<cuahang.Models.CartItem>

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase">Xác nhận đơn hàng</h2>
        <p class="text-muted">Vui lòng kiểm tra kỹ thông tin và chi tiết hóa đơn trước khi đặt hàng</p>
    </div>

    <form asp-controller="Cart" asp-action="ConfirmOrder" method="post" id="checkoutForm">
        <input type="hidden" name="KMCode" id="hiddenKMCode" value="">
        <input type="hidden" name="GiamGiaValue" id="hiddenGiamGiaValue" value="0">

        <div class="row">
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 p-4 mb-4">
                    <h5 class="mb-4 border-bottom pb-2">
                        <i class="bi bi-geo-alt-fill text-danger"></i> Thông tin giao hàng
                    </h5>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ nhận hàng <span class="text-danger">*</span></label>
                        <textarea name="DiaChi" class="form-control" rows="3" required
                                  placeholder="Ghi rõ số nhà, tên đường, phường/xã, quận/huyện..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Số điện thoại liên lạc <span class="text-danger">*</span></label>
                        <input type="tel" name="SoDienThoai" class="form-control" required
                               placeholder="Ví dụ: 0912345678">
                    </div>

                    <h5 class="mt-4 mb-3 border-bottom pb-2">
                        <i class="bi bi-ticket-perforated-fill text-success"></i> Mã giảm giá
                    </h5>
                    <div class="input-group mb-2">
                        <input type="text" id="voucherInput" class="form-control" placeholder="Nhập mã khuyến mãi của bạn...">
                        <button type="button" class="btn btn-dark" onclick="applyVoucher()">Áp dụng</button>
                    </div>
                    <div id="voucherMessage" class="small"></div>

                    <h5 class="mt-4 mb-3 border-bottom pb-2">
                        <i class="bi bi-credit-card-fill text-primary"></i> Hình thức thanh toán
                    </h5>
                    <div class="list-group">
                        <label class="list-group-item d-flex gap-3 py-3 border rounded shadow-sm">
                            <input class="form-check-input flex-shrink-0" type="radio" name="PaymentMethod" value="COD" checked>
                            <span>
                                <strong class="d-block">Thanh toán khi nhận hàng (COD)</strong>
                                <small class="d-block text-muted">Kiểm tra hàng và thanh toán tiền mặt trực tiếp cho shipper.</small>
                            </span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card shadow-sm border-0 p-4 bg-white border">
                    <h5 class="mb-4 border-bottom pb-2">Chi tiết hóa đơn</h5>

                    <div class="product-list mb-4" style="max-height: 350px; overflow-y: auto;">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex justify-content-between align-items-start mb-3 border-bottom pb-2">
                                <div class="d-flex align-items-start">
                                    <img src="~/image/@item.ImageUrl" width="50" class="rounded border me-2">
                                    <div>
                                        <h6 class="mb-0 fw-bold small">@item.TenSP</h6>
                                        <small class="text-muted">SL: @item.SoLuong x @item.Gia.ToString("N0")</small>
                                    </div>
                                </div>
                                <span class="fw-bold small">@item.ThanhTien.ToString("N0") đ</span>
                            </div>
                        }
                    </div>

                    <div class="billing-details bg-light p-3 rounded">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tổng tiền hàng:</span>
                            <span class="fw-bold" id="txtTongTienHang">@ViewBag.TongTienHang.ToString("N0") đ</span>
                        </div>

                        <div class="d-flex justify-content-between mb-2 text-success d-none" id="rowGiamGia">
                            <span><i class="bi bi-tag-fill"></i> Giảm giá:</span>
                            <span id="txtGiamGia">- 0 đ</span>
                        </div>

                        <hr class="my-2">

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="h5 fw-bold mb-0">Tổng cộng:</span>
                            <div class="text-end">
                                <span class="h4 text-danger fw-bold d-block mb-0" id="txtTongThanhToan">@ViewBag.TongTienHang.ToString("N0") đ</span>
                                <small class="text-muted">(Đã bao gồm VAT)</small>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-danger btn-lg w-100 mt-4 py-3 fw-bold shadow-sm border-0">
                        ĐẶT HÀNG NGAY
                    </button>

                    <div class="text-center mt-3">
                        <a asp-controller="Cart" asp-action="Index" class="text-decoration-none text-muted small fw-bold">
                            <i class="bi bi-arrow-left"></i> QUAY LẠI GIỎ HÀNG
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function applyVoucher() {
            var code = $('#voucherInput').val();
            if (!code) {
                alert("Vui lòng nhập mã!");
                return;
            }

            $.ajax({
                url: '/Cart/CheckVoucher',
                type: 'POST',
                data: { code: code },
                success: function (res) {
                    if (res.success) {
                        $('#voucherMessage').text(res.message).removeClass('text-danger').addClass('text-success');
                        $('#rowGiamGia').removeClass('d-none');
                        $('#txtGiamGia').text('- ' + res.discountAmount.toLocaleString() + ' đ');
                        $('#txtTongThanhToan').text(res.newTotal.toLocaleString() + ' đ');
                        $('#hiddenKMCode').val(code);
                        $('#hiddenGiamGiaValue').val(res.discountAmount);
                    } else {
                        $('#voucherMessage').text(res.message).removeClass('text-success').addClass('text-danger');
                        resetVoucher();
                    }
                },
                error: function () {
                    alert("Lỗi kết nối máy chủ!");
                }
            });
        }

        function resetVoucher() {
            $('#rowGiamGia').addClass('d-none');
            $('#txtTongThanhToan').text($('#txtTongTienHang').text());
            $('#hiddenKMCode').val('');
            $('#hiddenGiamGiaValue').val(0);
        }

        $('#checkoutForm').on('submit', function (e) {
            const sdt = $('input[name="SoDienThoai"]').val();
            if (!/^\d{10,11}$/.test(sdt)) {
                alert("Số điện thoại phải từ 10-11 số!");
                e.preventDefault();
            }
        });
    </script>
}