@model IEnumerable<cuahang.Models.CartItem>

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-uppercase">Xác nhận đơn hàng</h2>
        <p class="text-muted">Vui lòng kiểm tra kỹ thông tin và chi tiết hóa đơn trước khi đặt hàng</p>
    </div>

    <form asp-controller="Cart" asp-action="ConfirmOrder" method="post">
        <div class="row">
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 p-4 mb-4">
                    <h5 class="mb-4 border-bottom pb-2">
                        <i class="bi bi-geo-alt-fill text-danger"></i> Thông tin giao hàng
                    </h5>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ nhận hàng <span class="text-danger">*</span></label>
                        <textarea name="DiaChi" class="form-control" rows="3" required
                                  placeholder="Ghi rõ số nhà, tên đường, phường/xã, quận/huyện..."></textarea>
                        <div class="form-text">Chúng tôi sẽ giao hàng đến địa chỉ này.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Số điện thoại liên lạc <span class="text-danger">*</span></label>
                        <input type="tel" name="SoDienThoai" class="form-control" required
                               placeholder="Ví dụ: 0912345678" pattern="[0-9]{10,11}">
                        <div class="form-text">Số điện thoại dùng để shipper liên lạc khi giao hàng.</div>
                    </div>

                    <h5 class="mt-4 mb-3 border-bottom pb-2">
                        <i class="bi bi-credit-card-fill text-primary"></i> Hình thức thanh toán
                    </h5>
                    <div class="list-group">
                        <label class="list-group-item d-flex gap-3 py-3 border rounded shadow-sm">
                            <input class="form-check-input flex-shrink-0" type="radio" name="PaymentMethod" value="COD" checked>
                            <span>
                                <strong class="d-block">Thanh toán khi nhận hàng (COD)</strong>
                                <small class="d-block text-muted">Kiểm tra hàng và thanh toán tiền mặt trực tiếp cho nhân viên giao hàng.</small>
                            </span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card shadow-sm border-0 p-4 bg-white border">
                    <h5 class="mb-4 border-bottom pb-2">Chi tiết hóa đơn</h5>

                    <div class="product-list mb-4" style="max-height: 400px; overflow-y: auto;">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex justify-content-between align-items-start mb-4 border-bottom pb-3">
                                <div class="d-flex align-items-start">
                                    <div class="text-center me-3" style="width: 70px;">
                                        <img src="~/image/@item.ImageUrl" width="60" class="rounded border shadow-sm"
                                             onerror="this.src='/image/default.jpg'">
                                        <div class="mt-1">
                                            <span class="badge bg-light text-dark border fw-normal">
                                                SL: @item.SoLuong
                                            </span>
                                        </div>
                                    </div>

                                    <div>
                                        <h6 class="mb-1 fw-bold text-wrap" style="max-width: 180px;">@item.TenSP</h6>
                                        <small class="text-muted d-block">Đơn giá: @item.Gia.ToString("N0") đ</small>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <span class="fw-bold d-block">@item.ThanhTien.ToString("N0")</span>
                                    <small class="text-muted">VNĐ</small>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="billing-details bg-light p-3 rounded">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tổng tiền hàng:</span>
                            <span class="fw-bold">@ViewBag.TongTienHang.ToString("N0") VNĐ</span>
                        </div>

                        @if (ViewBag.PhanTramGiam > 0)
                        {
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span><i class="bi bi-tag-fill"></i> Voucher giảm giá (@ViewBag.PhanTramGiam%):</span>
                                <span>- @ViewBag.VoucherGiam.ToString("N0") VNĐ</span>
                            </div>
                        }

                        <hr class="my-2">

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="h5 fw-bold mb-0">Tổng thanh toán:</span>
                            <div class="text-end">
                                <span class="h4 text-danger fw-bold d-block mb-0">@ViewBag.TongThanhToan.ToString("N0") VNĐ</span>
                                <small class="text-muted">(Đã bao gồm VAT)</small>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-danger btn-lg w-100 mt-4 py-3 fw-bold shadow-sm border-0">
                        <i class="bi bi-bag-check-fill me-2"></i> ĐẶT HÀNG NGAY
                    </button>

                    <a asp-action="Index" class="btn btn-link w-100 text-decoration-none mt-2 text-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại chỉnh sửa giỏ hàng
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelector('form').addEventListener('submit', function (e) {
            const sdt = document.querySelector('input[name="SoDienThoai"]').value;
            if (sdt.length < 10 || sdt.length > 11) {
                alert("Số điện thoại không hợp lệ. Vui lòng kiểm tra lại!");
                e.preventDefault();
            }
        });
    </script>
}