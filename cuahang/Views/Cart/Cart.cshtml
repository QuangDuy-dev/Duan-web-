<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đơn hàng</title>
    <link rel="stylesheet" href="./style.css">
</head>
<body>
    <div class="container">
        <div class="topnav">
            <a href="">Trang chủ</a>
            <a href="">News</a>
            <a href="">Liên hệ</a>
            <a href="">Thông tin</a>
        </div>

        <div class="app-container">
            <div class="form-section">
                <h2 class="section-title">Nhập thông tin đơn hàng:</h2>
                
                <div class="form-group">
                    <label for="customerName">Tên người nhận:</label>
                    <input type="text" id="customerName" placeholder="Enter customer name">
                </div>

                <div class="form-group">
                    <label for="businessAddress">Địa chỉ giao hàng:</label>
                    <textarea id="businessAddress" rows="2" placeholder="Enter business address"></textarea>
                </div>
                
                <div class="form-group">
                    <label for="businessPhone">Số điện thoại liên hệ:</label>
                    <input type="text" id="businessPhone" placeholder="Enter business phone">
                </div>
                
                <div class="form-group">
                    <label for="receiptNumber">ID</label>
                    <input type="text" id="receiptNumber" placeholder="e.g., RCPT-001">
                </div>
               
                <div class="form-group">
                    <label for="paymentMethod">Cách thanh toán</label>
                    <select id="paymentMethod">
                        <option value="Cash">Tiền mặt</option>
                        <option value="Credit Card">Visa</option>
                        <option value="Debit Card">QR pay</option>
                        <option value="Bank Transfer">Tài khoản ngân hàng</option>
                        <option value="Digital Wallet">Ví điện tử</option>
                    </select>
                </div>
                
                <h2 class="section-title" style="margin-top: 30px;">Items</h2>
                
                <div class="form-group">
                    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr auto; gap: 10px; margin-bottom: 10px;">
                        <input type="text" id="itemName" placeholder="Item name">
                        <input type="number" id="itemPrice" placeholder="Price" min="0" step="0.01">
                        <input type="number" id="itemQuantity" placeholder="Qty" min="1" value="1">
                        <button class="btn btn-primary action-btn" id="addItem">Add</button>
                    </div>
                </div>
                
                <table class="items-table">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Giá</th>
                            <th>Số lượng</th>
                            <th>Tổng tiền</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="itemsList">
                        <tr>
                            <td colspan="5" class="empty-state">
                                <div>Chưa có sản phẩm</div>
                            </td>
                        </tr>
                    </tbody>
                </table>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 20px;">
                    <div class="form-group">
                        <label for="taxRate">Thuế (%)</label>
                        <input type="number" id="taxRate" placeholder="0" min="0" step="0.1" value="0">
                    </div>
                    
                    <div class="form-group">
                        <label for="discount">Khuyến mãi</label>
                        <input type="number" id="discount" placeholder="0" min="0" step="0.01" value="0">
                    </div>
                </div>
                
                <div class="controls no-print">
                    <button class="btn btn-primary" id="generateReceipt">Xác nhận đơn hàng</button>
                    <button class="btn btn-outline" id="clearAll">Hủy đơn hàng</button>
                </div>
            </div>
            
            <div class="preview-section">
                <h2 class="section-title">Hóa đơn:</h2>
                
                <div class="template-selector no-print">
                </div>
                
                <div class="receipt" id="receiptPreview">
                    <div class="receipt-header">
                        <h2 id="previewBusinessName">Business Name</h2>
                        <p id="previewBusinessAddress">Địa chỉ khách hàng</p>
                        <p id="previewBusinessPhone">Số điện thoại</p>
                    </div>
                    
                    <div class="receipt-body">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 15px;">
                            <div>
                                <strong>ID:</strong> <span id="previewReceiptNumber">RCPT-001</span>
                            </div>
                            <div>
                                <strong>Ngày đặt hàng:</strong> <span id="previewDate">Loading...</span>
                            </div>
                        </div>
                        
                        <div style="margin-bottom: 15px;">
                            <strong>Họ tên người nhận:</strong> <span id="previewCustomerName">Customer Name</span>
                        </div>
                        
                        <table class="receipt-items">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th class="text-right">Giá tiền</th>
                                    <th class="text-right">Số lượng</th>
                                    <th class="text-right">Tổng giá trị</th>
                                </tr>
                            </thead>
                            <tbody id="previewItems">
                                <tr>
                                    <td colspan="4" style="text-align: center; padding: 20px;">
                                        Chưa có sản phẩm nào
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <table class="receipt-totals">
                            <tr>
                                <td>Tổng chưa thuế:</td>
                                <td class="text-right">$<span id="previewSubtotal">0.00</span></td>
                            </tr>
                            <tr>
                                <td>Thuế (%) (<span id="previewTaxRate">0</span>%):</td>
                                <td class="text-right">$<span id="previewTax">0.00</span></td>
                            </tr>
                            <tr>
                                <td>Khuyến mãi:</td>
                                <td class="text-right">$<span id="previewDiscount">0.00</span></td>
                            </tr>
                            <tr class="total-row">
                                <td><strong>Tổng tiền:</strong></td>
                                <td class="text-right"><strong>$<span id="previewTotal">0.00</span></strong></td>
                            </tr>
                        </table>
                        
                        <div style="margin-top: 15px;">
                            <strong>Phương pháp trả tiền:</strong> <span id="previewPaymentMethod">Tiền mặt</span>
                        </div>
                    </div>
                    
                    <div class="receipt-footer">
                        <p>Cảm ơn vì đã mua hàng!</p>
                    </div>
                </div>
                
                <div class="controls no-print">
                    <button class="btn btn-success" id="printReceipt">In hóa đơn</button>
                </div>
            </div>
        </div>
    </div>

    <script src="./script.js"></script>
</body>
</html>