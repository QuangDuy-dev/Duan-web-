@model cuahang.Models.HoaDon

<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between">
            <h5 class="mb-0">Chi tiết đơn hàng #@Model.Id</h5>
            <span>Ngày đặt: @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6><strong>Thông tin khách hàng</strong></h6>
                    <p class="mb-1">Khách hàng: @(Model.User?.Name ?? "N/A")</p>
                    <p class="mb-1">Trạng thái: <span class="badge bg-info">@Model.TrangThai</span></p>
                </div>
            </div>

            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ct in Model.ChiTietHoaDons)
                    {
                            <tr>
                                <td>
                                    <strong>@ct.SanPham.TenSP</strong>
                                </td>
                                <td class="text-center">@ct.SoLuong</td>
                                <td class="text-end">@ct.DonGia.ToString("N0") đ</td>
                                <td class="text-end fw-bold">@((ct.SoLuong * ct.DonGia).ToString("N0")) đ</td>
                            </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold text-uppercase">Tổng cộng:</td>
                        <td class="text-end text-danger fs-5 fw-bold">@Model.TongTien.ToString("N0") đ</td>
                    </tr>
                </tfoot>
            </table>

            <div class="mt-3">
                <a href="@Url.Action("LichSuDonHangUser")" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>