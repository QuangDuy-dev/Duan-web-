@model cuahang.Models.HoaDon

@{
    // Giả định Model HoaDon của bạn có các thuộc tính này từ trang Xác nhận
    // Nếu tên thuộc tính trong class HoaDon khác, hãy đổi lại cho khớp (ví dụ: Model.Address, Model.Phone)
    var tongTienHang = Model.ChiTietHoaDons.Sum(ct => ct.SoLuong * ct.DonGia);
    var soTienGiam = Model.GiamGia; // Thuộc tính lưu số tiền voucher (ví dụ: 10.350.000)
    var tongThanhToan = Model.TongTien; // Thường TongTien đã là số cuối cùng sau khi trừ voucher
}

<div class="container mt-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Chi tiết đơn hàng #@Model.Id</h5>
            <span>Ngày đặt: @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="text-primary fw-bold text-uppercase border-bottom pb-2">Thông tin khách hàng</h6>
                    <p class="mb-1"><strong>Khách hàng:</strong> @(Model.User?.Name ?? "N/A")</p>

                    @* THÊM MỚI: Hiển thị Địa chỉ và Số điện thoại *@
                    <p class="mb-1"><strong>Địa chỉ:</strong> @(Model.DiaChi ?? "Chưa cập nhật")</p>
                    <p class="mb-1"><strong>Số điện thoại:</strong> @(Model.SoDienThoai ?? "Chưa cập nhật")</p>

                    <p class="mb-1"><strong>Trạng thái:</strong> <span class="badge bg-info text-dark">@Model.TrangThai</span></p>
                </div>
            </div>

            <table class="table table-bordered align-middle">
                <thead class="table-light text-center">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                        <th>Đánh giá</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ct in Model.ChiTietHoaDons)
                    {
                        <tr>
                            <td>
                                <strong>@ct.SanPham.TenSP</strong>
                            </td>
                            <td class="text-center">@ct.SoLuong</td>
                            <td class="text-end">@ct.DonGia.ToString("N0") đ</td>
                            <td class="text-end fw-bold">@((ct.SoLuong * ct.DonGia).ToString("N0")) đ</td>
                            <td class="text-center">
                                @if (Model.TrangThai == "Hoàn thành")
                                {
                                    <div class="rating-stars" data-id="@ct.Id">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi @(ct.DiemDanhGia >= i ? "bi-star-fill text-warning" : "bi-star") star-item"
                                               style="cursor:pointer; font-size: 1.3rem;"
                                               onclick="submitRating(@ct.Id, @i)"></i>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted small">Chờ hoàn thành</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    @* LOGIC HIỂN THỊ CHI TIẾT THANH TOÁN *@
                    <tr>
                        <td colspan="3" class="text-end fw-bold">Tổng tiền hàng:</td>
                        <td class="text-end">@tongTienHang.ToString("N0") đ</td>
                    </tr>

                    @if (soTienGiam > 0)
                    {
                        <tr>
                            <td colspan="3" class="text-end fw-bold text-success">Voucher giảm giá:</td>
                            <td class="text-end text-success">- @soTienGiam.ToString("N0") đ</td>
                        </tr>
                    }

                    <tr>
                        <td colspan="3" class="text-end fw-bold text-uppercase">Tổng thanh toán:</td>
                        <td class="text-end text-danger fs-5 fw-bold">@Model.TongTien.ToString("N0") đ</td>
                    </tr>
                </tfoot>
            </table>

            <div class="mt-3">
                <a href="@Url.Action("LichSuDonHangUser")" class="btn btn-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    /* Hiệu ứng khi di chuột vào ngôi sao */
    .star-item:hover {
        transform: scale(1.2);
        color: #ffc107 !important;
    }

    .star-item {
        transition: all 0.2s;
        margin: 0 2px;
    }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function submitRating(id, stars) {
        // Gửi yêu cầu lưu số sao tới Controller
        $.post('/Account/DanhGiaSanPham', { chiTietId: id, soSao: stars }, function(res) {
            if(res.success) {
                location.reload();
            } else {
                alert("Có lỗi xảy ra, vui lòng thử lại!");
            }
        });
    }
</script>