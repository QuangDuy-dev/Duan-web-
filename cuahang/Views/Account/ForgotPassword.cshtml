@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<link rel="stylesheet" href="~/css/login.css" />
<link rel="stylesheet" href="~/css/forgot-password.css" />

<div class="container">
    <div class="form-box active forgot-password-box">
        <form asp-action="VerifyOTP" method="post">
            @Html.AntiForgeryToken()
            <h2>Reset Password</h2>

            <div class="step-group">
                <p class="step-title">1. Nhập Email đăng ký:</p>
                <div class="email-row">
                    <input type="email" name="email" id="userEmail" placeholder="Your Email" required />
                    <button type="button" onclick="sendOTPRequest()" id="btnSendOTP" class="btn-get-otp">Get OTP</button>
                </div>
            </div>

            <div class="step-group step-divider">
                <p class="step-title">2. Nhập mã OTP (6 số):</p>
                <input type="text" name="otp" placeholder="Enter 6-digit OTP" required maxlength="6" />
                <button type="submit" class="btn-verify">Verify & Continue</button>
            </div>

            <a asp-action="Login" class="back-link">Back to Login</a>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    async function sendOTPRequest() {
        const email = document.getElementById('userEmail').value;
        if (!email) {
            Swal.fire('Chú ý', 'Vui lòng nhập email trước khi lấy mã!', 'warning');
            return;
        }

        const btn = document.getElementById('btnSendOTP');
        const originalText = btn.innerText;
        btn.innerText = "Sending...";
        btn.disabled = true;

        try {
            const response = await fetch(`/Account/SendOTP?email=${email}`, { method: 'POST' });
            if (response.ok) {
                Swal.fire('Thành công', 'Mã OTP đã được gửi!', 'success');
                btn.innerText = "Resend";
            } else {
                Swal.fire('Lỗi', 'Email không tồn tại!', 'error');
                btn.innerText = originalText;
            }
        } catch (error) {
            Swal.fire('Lỗi', 'Lỗi kết nối server!', 'error');
            btn.innerText = originalText;
        } finally {
            btn.disabled = false;
        }
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            title: 'SUCCESS!',
            html: '@Html.Raw(TempData["Success"])',
            icon: 'success',
            confirmButtonText: 'OK'
        });
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        Swal.fire({
            title: 'ERROR!',
            html: '@Html.Raw(TempData["Error"])',
            icon: 'error',
            confirmButtonText: 'Thử lại'
        });
    </script>
}