@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<link rel="stylesheet" href="~/css/login.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container">
    <div class="form-box active">
        <form asp-action="Register" method="post">
            <h2>Register</h2>

            <input type="text" name="username" placeholder="Username" required />

            <input type="text"
                   name="email"
                   placeholder="Email (ví dụ: user@gmail.com)"
                   required
                   pattern="^[^@@\s]+@@[^@@\s]+\.com$"
                   title="Email phải có định dạng đúng và kết thúc bằng .com" />

            <input type="password"
                   name="password"
                   id="password"
                   placeholder="Password"
                   required
                   pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[@@$!%*?&]).{8,}"
                   title="Ít nhất 8 ký tự, gồm chữ hoa, thường, số và ký tự đặc biệt (@@$!%*?&)" />

            <input type="password"
                   name="confirmPassword"
                   id="confirmPassword"
                   placeholder="Confirm Password"
                   required />

            <button type="submit">Register</button>

            <p>
                Already have an account?
                <a asp-action="Login">Login</a>
            </p>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <script>
        Swal.fire({
            title: 'SUCCESS!',
            html: '@Html.Raw(TempData["Success"])',
            icon: 'success',
            confirmButtonText: 'OK'
        });
    </script>
}

@if (TempData["Error"] != null)
{
    <script>
        Swal.fire({
            title: 'ERROR!',
            html: '@Html.Raw(TempData["Error"])',
            icon: 'error',
            confirmButtonText: 'Thử lại'
        });
    </script>
}

<script>
    const password = document.getElementById("password");
    const confirmPass = document.getElementById("confirmPassword");

    function validate() {
        if (password.value !== confirmPass.value) {
            confirmPass.setCustomValidity("Mật khẩu không khớp");
        } else {
            confirmPass.setCustomValidity("");
        }
    }
    password.onchange = validate;
    confirmPass.onkeyup = validate;
</script>