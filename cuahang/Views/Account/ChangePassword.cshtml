@{
    ViewData["Title"] = "Change Password";
    Layout = null;
}
<link rel="stylesheet" href="~/css/login.css" />

<div class="container">
    <div class="form-box active">
        <form asp-action="ConfirmChangePassword" method="post">
            @Html.AntiForgeryToken()
            <h2>New Password</h2>

            <input type="hidden" name="email" value="@ViewBag.Email" />

            <p style="font-size: 0.8em; color: #666; margin-bottom: 15px;">
                Thiết lập mật khẩu mới cho: <strong>@ViewBag.Email</strong>
            </p>

            <input type="password" name="newPassword" placeholder="New Password" required />
            <input type="password" name="confirmPassword" placeholder="Confirm Password" required />

            <button type="submit">Update Password</button>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
@if (TempData["Error"] != null)
{
    <script>Swal.fire('LỖI!', '@TempData["Error"]', 'error');</script>
}