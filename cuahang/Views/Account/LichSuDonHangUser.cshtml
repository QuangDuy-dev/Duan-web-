@model IEnumerable<cuahang.Models.HoaDon>
@{
    ViewBag.Title = "Đơn hàng của tôi";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 text-primary"><i class="bi bi-bag-check-fill"></i> Lịch sử mua hàng</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Mã đơn</th>
                                    <th>Ngày mua</th>
                                    
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th class="text-center">Chi tiết</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                        <tr class="align-middle">
                                            <td class="ps-4 fw-bold">#@item.Id</td>
                                            <td>@item.NgayDat.ToString("dd/MM/yyyy")</td>
                                          
                                            <td class="text-danger fw-bold">@item.TongTien.ToString("N0") đ</td>
                                            <td>
                                            @if (item.TrangThai == "Đang giao")
                                            {
                                                        <span class="badge rounded-pill bg-info text-dark">Đang giao</span>
                                            }
                                            else
                                            {
                                                        <span class="badge rounded-pill bg-secondary">@item.TrangThai</span>
                                            }
                                            </td>
                                                <td class="text-center">
                                                    <a href="@Url.Action("ChiTietDonHang", "Account", new { id = item.Id })" class="btn btn-outline-primary btn-sm">
                                                    <i class="bi bi-eye"></i> Xem
                                                </a>
                                            </td>
                                        </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>